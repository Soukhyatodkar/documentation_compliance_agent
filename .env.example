# ============================================================================
# Documentation Compliance Agent - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================================

# ---- LLM Configuration ----
# OpenAI API Key (required for LLM comparisons)
OPENAI_API_KEY=sk-your-key-here
# LLM Model to use for comparisons
LLM_MODEL=gpt-4
# Temperature for LLM responses (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.7
# Max tokens for LLM responses
LLM_MAX_TOKENS=2000

# ---- Embedding Configuration ----
# OpenAI Embedding Model
EMBEDDING_MODEL=text-embedding-3-small
# Embedding dimensions (depends on model)
EMBEDDING_DIMENSIONS=1536

# ---- Vector Database Configuration ----
# Qdrant server URL (local or remote)
QDRANT_URL=http://localhost:6333
# Qdrant API key (if required)
QDRANT_API_KEY=
# Qdrant collection name for guideline embeddings
QDRANT_COLLECTION_NAME=guidelines
# Vector size for Qdrant (must match embeddings)
QDRANT_VECTOR_SIZE=1536

# ---- Website Configuration ----
# Target website URL
WEBSITE_URL=https://example.com
# Website login username (if required)
WEBSITE_USERNAME=
# Website login password (if required)
WEBSITE_PASSWORD=
# Website login URL (if different from WEBSITE_URL)
WEBSITE_LOGIN_URL=

# ---- Authentication Configuration ----
# Type of authentication: none, basic, form, oauth2
AUTH_TYPE=none
# Session cookie name (for cookie-based auth)
AUTH_COOKIE_NAME=
# Auth token header name (for token-based auth)
AUTH_TOKEN_HEADER=Authorization
# Auth token value (if using token-based auth)
AUTH_TOKEN_VALUE=

# ---- PDF Configuration ----
# Path to the PDF guideline document
PDF_PATH=./data/pdfs/guidelines.pdf
# How to handle multi-page PDFs
PDF_STRATEGY=semantic
# Minimum chunk size for PDF
PDF_CHUNK_MIN_SIZE=100
# Maximum chunk size for PDF
PDF_CHUNK_MAX_SIZE=1000
# Overlap between chunks (characters)
PDF_CHUNK_OVERLAP=100

# ---- Web Extraction Configuration ----
# Browser headless mode (true/false)
BROWSER_HEADLESS=true
# Browser type: chromium, firefox, webkit
BROWSER_TYPE=chromium
# Viewport width for screenshots
VIEWPORT_WIDTH=1280
# Viewport height for screenshots
VIEWPORT_HEIGHT=720
# Wait time for page to load (milliseconds)
PAGE_LOAD_TIMEOUT=30000
# Wait time for element to appear (milliseconds)
ELEMENT_WAIT_TIMEOUT=10000
# Screenshot quality (1-100)
SCREENSHOT_QUALITY=90
# Take full page screenshots
SCREENSHOT_FULL_PAGE=true
# Take element screenshots
SCREENSHOT_ELEMENTS=true

# ---- Extraction Configuration ----
# Maximum pages to extract from website
MAX_PAGES=100
# Maximum links to follow
MAX_LINKS=500
# Skip these URL patterns (comma-separated regex patterns)
SKIP_URLS=logout,signout,delete.*account,admin.*
# Only crawl these URL patterns (empty = all, comma-separated regex)
ALLOWED_URL_PATTERNS=
# Wait for these selectors to appear (comma-separated CSS selectors)
WAIT_FOR_SELECTORS=.main-content,.page-container,.app
# Execute JavaScript before extraction
EXECUTE_JS=
# Scroll behavior: none, auto, full, lazy
SCROLL_BEHAVIOR=full

# ---- Retry Configuration ----
# Maximum number of retries for failed page extractions
MAX_RETRIES=3
# Initial retry delay (milliseconds)
RETRY_DELAY_MS=1000
# Exponential backoff multiplier
RETRY_BACKOFF_MULTIPLIER=2.0
# Max retry delay (milliseconds)
MAX_RETRY_DELAY_MS=30000

# ---- Coverage Configuration ----
# Minimum coverage percentage to consider successful
MIN_COVERAGE_PERCENTAGE=80
# Track failed pages separately
TRACK_FAILED_PAGES=true
# Track authentication failures
TRACK_AUTH_FAILURES=true

# ---- Output Configuration ----
# Output directory for reports and extracted data
OUTPUT_DIR=./data
# Report directory
REPORT_DIR=./data/reports
# Screenshot directory
SCREENSHOT_DIR=./data/screenshots
# Extracted data directory
EXTRACTED_DIR=./data/extracted

# ---- Report Configuration ----
# Generate Markdown report
REPORT_MARKDOWN=true
# Generate JSON report
REPORT_JSON=true
# Generate HTML report
REPORT_HTML=true
# Include screenshots in HTML report
REPORT_INCLUDE_SCREENSHOTS=true
# Minimum confidence score to include in report (0.0-1.0)
REPORT_MIN_CONFIDENCE=0.6
# Group discrepancies by severity
REPORT_GROUP_BY_SEVERITY=true

# ---- Logging Configuration ----
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Log format: simple, json, structured
LOG_FORMAT=structured
# Log file path
LOG_FILE=./logs/agent.log
# Rotate logs by size (MB)
LOG_ROTATION_SIZE_MB=10
# Keep backup logs
LOG_BACKUP_COUNT=5
# Log SQL queries
LOG_SQL_QUERIES=false
# Log HTTP requests
LOG_HTTP_REQUESTS=false
# Log embeddings generation
LOG_EMBEDDINGS=false

# ---- Performance Configuration ----
# Number of concurrent page extraction workers
CONCURRENT_WORKERS=3
# Number of concurrent embedding jobs
EMBEDDING_BATCH_SIZE=50
# Cache embeddings
USE_EMBEDDING_CACHE=true
# Cache TTL (hours)
CACHE_TTL_HOURS=24

# ---- Testing Configuration ----
# Use mock data for testing
USE_MOCK_DATA=false
# Mock data file path
MOCK_DATA_FILE=./tests/fixtures/mock_data.json
# Enable test mode
TEST_MODE=false

# ---- Advanced Configuration ----
# Proxy URL (if needed)
PROXY_URL=
# Enable performance monitoring
ENABLE_MONITORING=true
# Monitoring port
MONITORING_PORT=8000
# Enable debug mode
DEBUG_MODE=false
# Dry run (don't write to vector DB)
DRY_RUN=false
# Strict mode (fail on first error)
STRICT_MODE=false
